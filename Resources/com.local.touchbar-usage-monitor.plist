<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.local.touchbar-usage-monitor</string>
    <key>ProgramArguments</key>
    <array>
        <string>__APP_PATH__</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>TUM_ANTIGRAVITY_WORKSPACE</key>
